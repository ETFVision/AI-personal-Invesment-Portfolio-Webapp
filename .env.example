NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
FMP_API_KEY=

# Product mode controls feature surface. "full" shows everything (use for local dev).
# "alpha" hides News, Macro, Assistant, Telemetry, and Admin nav and blocks those routes.
# Default when unset is "alpha". Set PRODUCT_MODE=full in .env.local for local development.
PRODUCT_MODE=full

# Admin authorization allowlists. Empty values deny all admin access.
# Prefer ADMIN_USER_IDS with Supabase auth UUIDs; ADMIN_EMAILS is optional bootstrap support.
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Signup access control. Empty means open signup for development; set comma-separated emails for invite-only alpha/production.
ALLOWED_SIGNUP_EMAILS=

OPENAI_API_KEY=
ENABLE_PORTFOLIO_ASSISTANT=true

# Portfolio Assistant OpenAI model and pricing. Current pricing: https://openai.com/api/pricing/
PORTFOLIO_ASSISTANT_MODEL=gpt-5.4-mini
PORTFOLIO_ASSISTANT_INPUT_COST_PER_1M=0.75
PORTFOLIO_ASSISTANT_OUTPUT_COST_PER_1M=4.50

# Per-user daily assistant conversation cap. 0 means unlimited.
ASSISTANT_DAILY_LIMIT=0

# Market Vision OpenAI model and pricing. Current pricing: https://openai.com/api/pricing/
MARKET_VISION_MODEL=gpt-5.4-mini
MARKET_VISION_INPUT_COST_PER_1M=0.75
MARKET_VISION_OUTPUT_COST_PER_1M=4.50
